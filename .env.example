# Supabase — copia a .env.local y rellena con tus credenciales reales
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Solo servidor (nunca exponer al cliente). Para seed / tareas admin.
SUPABASE_SERVICE_ROLE_KEY=""

# Slug secreto que oculta /admin. Visitar tudominio.com/<slug> abre la puerta.
# NO usar prefijo NEXT_PUBLIC (debe quedar solo en servidor).
ADMIN_GATE_SLUG=""

# Notificaciones push (Web Push / VAPID). Generar con: npx web-push generate-vapid-keys
# La pública va al cliente (NEXT_PUBLIC); la privada y el subject solo en servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-correo@ejemplo.com"

# Protege la ruta del cron (/api/cron/notificaciones). Vercel Cron lo envía
# automáticamente como Authorization: Bearer <valor> si esta var existe en Vercel.
CRON_SECRET=""
